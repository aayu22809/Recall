{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Raycast Extension",
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "node16",
    "target": "ES2022",
    "moduleResolution": "node16",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "react": ["./node_modules/@raycast/api/node_modules/@types/react"],
      "react/*": ["./node_modules/@raycast/api/node_modules/@types/react/*"]
    },
    "typeRoots": [
      "./node_modules/@raycast/api/node_modules/@types",
      "./node_modules/@types"
    ]
  },
  "include": ["src/**/*"]
}
