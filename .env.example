#
# Embedding provider:
#   gemini (default), ollama (local), nim (OpenAI-compatible endpoint)
#
VEF_EMBEDDING_PROVIDER=gemini

# Gemini settings (used when VEF_EMBEDDING_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
VEF_EMBEDDING_MODEL=gemini-embedding-2-preview
VEF_EMBEDDING_DIMENSIONS=768

# Ollama settings (used when VEF_EMBEDDING_PROVIDER=ollama)
# VEF_OLLAMA_BASE_URL=http://127.0.0.1:11434
# VEF_OLLAMA_EMBED_MODEL=nomic-embed-text
# VEF_OLLAMA_EMBED_URL=http://127.0.0.1:11434/api/embeddings

# NIM settings (used when VEF_EMBEDDING_PROVIDER=nim)
# NIM_API_KEY=your_nim_api_key_here
# VEF_NIM_EMBED_URL=https://integrate.api.nvidia.com/v1/embeddings
# VEF_NIM_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

